# Supabase → Settings → API
# Project URL (exactly this format — no /rest/v1, no quotes):
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# anon public key (not service_role):
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- Vercel deployment ---
# .env is NOT uploaded to Git. Add the same two variables in:
# Vercel → your project → Settings → Environment Variables
# Enable for Production (and Preview if you use preview URLs), then Redeploy.
